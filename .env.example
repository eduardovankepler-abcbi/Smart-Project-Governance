# ============================================
# ABC Project Manager - Variáveis de Ambiente (Produção)
# ============================================

# Banco de dados MySQL
DB_ROOT_PASSWORD=CHANGE_ME_root_password
DB_NAME=abc_project_manager
DB_USER=abc_app_user
DB_PASSWORD=CHANGE_ME_app_password

# API Key (obrigatório — gere com: openssl rand -hex 32)
API_KEY=CHANGE_ME_api_key

# Frontend → Backend URL
# Use `auto` quando o frontend publicado compartilhar o mesmo domínio da API via Nginx.
VITE_API_URL=http://localhost:3001
FRONTEND_PORT=80

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost,http://localhost:80
IMPORT_MAX_FILE_SIZE_MB=25

# Supabase (opcional, sincronização automática feita pelo backend)
SUPABASE_SYNC_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
